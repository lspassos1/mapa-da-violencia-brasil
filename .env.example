# Copie para .env.local e ajuste conforme necessario. Variaveis NEXT_PUBLIC_*
# sao expostas ao cliente em tempo de build.

# Modo de dados: "official_sample" usa a amostra oficial versionada;
# qualquer outro valor (ou ausente) recai em "demo".
NEXT_PUBLIC_CRIME_DATA_MODE=demo

# Tiles do mapa base. Lista de URLs separadas por virgula (o MapLibre distribui
# os pedidos pelas varias URLs). Por omissao usa os subdominios a/b/c/d do CARTO.
# NEXT_PUBLIC_MAP_TILE_URLS=https://a.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}.png,https://b.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}.png

# Atribuicao do mapa base (obrigatoria pelos ToS do provider de tiles).
# NEXT_PUBLIC_MAP_TILE_ATTRIBUTION=© OpenStreetMap contributors, © CARTO

# ---------------------------------------------------------------------------
# Provedores de IA (free tier) — camada OSINT de extracao de noticias.
# SEGREDOS DE SERVIDOR: sem NEXT_PUBLIC_, usar so em app/api/*. Valores reais
# vao em .env.local (ignorado pelo git) e/ou nas env vars da Vercel.
# Guia de uso: docs/AI_PROVIDERS.md
# ---------------------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_PROJECT_NUMBER=
GROQ_API_KEY=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
OPENROUTER_API_KEY=
MISTRAL_API_KEY=
TOGETHER_API_KEY=
